# Supabase Configuration for Restaurant SaaS Platform
#
# INSTRUCTIONS:
# 1. Copy this file to .env in the root directory
# 2. Fill in the values from Supabase Project Settings > API

# ============================================
# SUPABASE WEB SDK CONFIGURATION (for Vite apps)
# ============================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Optional: Use to override OAuth redirect when needed
VITE_SUPABASE_REDIRECT_URL=http://localhost:5173
